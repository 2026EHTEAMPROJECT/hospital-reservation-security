{
  "realm": "hospital",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "accessTokenLifespan": 3600,
  "roles": {
    "realm": [
      {
        "name": "PATIENT",
        "description": "환자"
      },
      {
        "name": "DOCTOR",
        "description": "의료진"
      },
      {
        "name": "ADMIN",
        "description": "관리자"
      }
    ]
  },
  "clients": [
    {
      "clientId": "hospital-frontend",
      "name": "Hospital Frontend (Public)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "*"
      ],
      "webOrigins": [
        "*"
      ],
      "attributes": {
        "post.logout.redirect.uris": "+"
      },
      "protocolMappers": [
        {
          "name": "phoneNumber",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "multivalued": "false",
            "user.attribute": "phoneNumber",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "phoneNumber",
            "jsonType.label": "String"
          }
        }
      ]
    },
    {
      "clientId": "hospital-services",
      "name": "Hospital Backend Services (Confidential)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "secret": "change-me-service-secret"
    }
  ],
  "users": [
    {
      "username": "patient1",
      "enabled": true,
      "email": "patient1@hospital.local",
      "emailVerified": true,
      "firstName": "Patient",
      "lastName": "One",
      "credentials": [
        {
          "type": "password",
          "value": "pass1234",
          "temporary": false
        }
      ],
      "realmRoles": [
        "PATIENT"
      ]
    },
    {
      "username": "doctor1",
      "enabled": true,
      "email": "doctor1@hospital.local",
      "emailVerified": true,
      "firstName": "Doctor",
      "lastName": "One",
      "credentials": [
        {
          "type": "password",
          "value": "pass1234",
          "temporary": false
        }
      ],
      "realmRoles": [
        "DOCTOR"
      ]
    },
    {
      "username": "admin1",
      "enabled": true,
      "email": "admin1@hospital.local",
      "emailVerified": true,
      "firstName": "Admin",
      "lastName": "One",
      "credentials": [
        {
          "type": "password",
          "value": "pass1234",
          "temporary": false
        }
      ],
      "realmRoles": [
        "ADMIN"
      ]
    }
  ],
  "components": {
    "org.keycloak.userprofile.UserProfileProvider": [
      {
        "providerId": "declarative-user-profile",
        "subComponents": {},
        "config": {
          "kc.user.profile.config": [
            "{\"attributes\":[{\"name\":\"username\",\"displayName\":\"${username}\",\"validations\":{\"length\":{\"min\":3,\"max\":255},\"username-prohibited-characters\":{},\"up-username-not-idn-homograph\":{}},\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]},\"multivalued\":false},{\"name\":\"email\",\"displayName\":\"${email}\",\"validations\":{\"email\":{},\"length\":{\"max\":255}},\"required\":{\"roles\":[\"user\"]},\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]},\"multivalued\":false},{\"name\":\"firstName\",\"displayName\":\"${firstName}\",\"validations\":{\"length\":{\"max\":255},\"person-name-prohibited-characters\":{}},\"required\":{\"roles\":[\"user\"]},\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]},\"multivalued\":false},{\"name\":\"lastName\",\"displayName\":\"${lastName}\",\"validations\":{\"length\":{\"max\":255},\"person-name-prohibited-characters\":{}},\"required\":{\"roles\":[\"user\"]},\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]},\"multivalued\":false},{\"name\":\"phoneNumber\",\"displayName\":\"전화번호\",\"validations\":{},\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]},\"multivalued\":false}],\"groups\":[{\"name\":\"user-metadata\",\"displayHeader\":\"User metadata\",\"displayDescription\":\"Attributes, which refer to user metadata\"}]}"
          ]
        }
      }
    ]
  }
}